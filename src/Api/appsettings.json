{
  "AllowedHosts": "*",

  "Serilog": {
    "Using": ["Serilog.Sinks.Console", "Serilog.Sinks.File"],
    "MinimumLevel": {
      "Default": "Warning",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.AspNetCore.Hosting": "Warning",
        "Microsoft.AspNetCore.Routing": "Warning",
        "Amazon": "Warning",
        "System.Net.Http.HttpClient": "Warning",
        "Application": "Information",
        "Domain": "Information"
      }
    },
    "CostOptimization": {
      "MinimumLevel": "Warning",
      "BufferSize": 1000,
      "LogFilePath": "/var/log/freeiranportal/app.log",
      "RetainedFileCountLimit": 7,
      "FileSizeLimitMb": 100,
      "FlushIntervalSeconds": 5
    },
    "RequestLogging": {
      "SlowRequestThresholdMs": 500,
      "SuccessfulRequestSampleRate": 1.0
    }
  },
  
  "AwsSecretsManager": {
    "SecretName": "free-iran-portal/production",
    "Region": "us-east-1"
  },
  
  "DynamoDB": {
    "TableName": "FreeIranPortal-Registrants",
    "ServiceUrl": "",
    "Region": "us-east-1"
  },
  
  "RateLimiting": {
    "PermitLimit": 100,
    "WindowMinutes": 1,
    "QueueLimit": 10
  },
  
  "Cors": {
    "AllowedOrigins": [
      "https://freeiranportal.org",
      "https://www.freeiranportal.org"
    ]
  }
}
