{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.AspNetCore": "Warning",
        "Amazon": "Information",
        "Application": "Debug",
        "Domain": "Debug"
      }
    },
    "RequestLogging": {
      "SlowRequestThresholdMs": 1000,
      "SuccessfulRequestSampleRate": 1.0
    }
  },

  "UseLocalSecrets": true,
  
  "DynamoDB": {
    "TableName": "FreeIranPortal-Registrants-Dev",
    "ServiceUrl": "http://localhost:8000",
    "Region": "local"
  },
  
  "RateLimiting": {
    "PermitLimit": 1000,
    "WindowMinutes": 1,
    "QueueLimit": 50
  },
  
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:5173",
      "http://localhost:5000"
    ]
  }
}
